{
  "name": "MeetLinks",
  "description": "Manage your Google Meet links.",
  "version": "1.0",
  "manifest_version": 3,
  "content_scripts": [{
    "matches": [
      "https://classroom.google.com/*"
    ],
    "js": ["/js/jquery-3.6.0.min.js", "/js/script.js"],
    "run_at": "document_start"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "/img/icon16.png",
      "32": "/img/icon32.png",
      "64": "/img/icon64.png",
      "128": "/img/icon128.png"
    }
  },
  "permissions": ["storage", "tabs"],
  "icons": {
    "16": "/img/icon16.png",
    "32": "/img/icon32.png",
    "64": "/img/icon64.png",
    "128": "/img/icon128.png"
  }
}
